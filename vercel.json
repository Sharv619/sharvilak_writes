{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python manage.py collectstatic --noinput",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{.claude/**,.git/**,venv/**,staticfiles/**,knowledge_base/media/**,knowledge_base/scraped_posts/**,knowledge_base/scripts/**,**/__pycache__/**,**/*.pyc,db.sqlite3}"
    }
  }
}
